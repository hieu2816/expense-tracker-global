# ===========================================
# Expense Tracking - Environment Variables
# ===========================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's already in .gitignore)
# ===========================================

# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Spring Boot Database Connection
# IMPORTANT: Choose the right URL for your environment
#
# For LOCAL development (IntelliJ, direct Java run):
#   DB_URL=jdbc:postgresql://localhost:5433/postgres
#   -> Connects via Docker host port (exposed as 5433:5432 in docker-compose.yaml)
#
# For DOCKER (docker-compose):
#   DB_URL=jdbc:postgresql://database:5432/postgres
#   -> docker-compose.yaml hardcodes this internally; .env DB_URL is ignored
#
# For CI/CD (GitHub Actions):
#   DB_URL=jdbc:postgresql://localhost:5432/postgres
#   -> Uses Docker service defined in deploy.yml
DB_URL=jdbc:postgresql://localhost:5433/postgres

DB_USERNAME=postgres
DB_PASSWORD=changeme

# Spring Profile
# Set to "prod" for production (loads application-prod.yaml)
# Leave unset or "default" for local development
SPRING_PROFILES_ACTIVE=prod

# JWT
JWT_SECRET=changeme

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://spendwiser.me

# =========================================
# TLS / Let's Encrypt (Production only)
# =========================================
# Used by script/bootstrap-tls.sh on first deploy to a fresh server.
# In CI/CD these are injected from GitHub Secrets automatically.
# For manual server setup: fill these in before running bootstrap-tls.sh

# Contact email for Let's Encrypt expiry notifications
LETSENCRYPT_EMAIL=your-email@example.com

# Primary domain for the SSL certificate
TLS_DOMAIN=spendwiser.me

# Set to "true" to use Let's Encrypt staging API (no rate limits — safe for testing)
# NEVER set to true in production; staging certs are not trusted by browsers
CERTBOT_STAGING=false

# =========================================
# Telegram Alerts (Monitoring)
# =========================================
# Used by script/monitor.sh and script/smoke-test.sh to send alerts.
# In CI/CD these are injected from GitHub Secrets automatically.

TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id