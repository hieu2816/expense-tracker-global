# ===========================================
# Expense Tracking - Environment Variables
# ===========================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's already in .gitignore)
# ===========================================

# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Spring Boot Database Connection
# IMPORTANT: Choose the right URL for your environment
#
# For LOCAL development (IntelliJ, direct Java run):
#   DB_URL=jdbc:postgresql://localhost:5433/postgres
#   -> Connects via Docker host port (exposed as 5433:5432 in docker-compose.yaml)
#
# For DOCKER (docker-compose):
#   DB_URL=jdbc:postgresql://database:5432/postgres
#   -> docker-compose.yaml hardcodes this internally; .env DB_URL is ignored
#
# For CI/CD (GitHub Actions):
#   DB_URL=jdbc:postgresql://localhost:5432/postgres
#   -> Uses Docker service defined in deploy.yml
DB_URL=jdbc:postgresql://localhost:5433/postgres

DB_USERNAME=postgres
DB_PASSWORD=changeme

# Spring Profile
# Set to "prod" for production (loads application-prod.yaml)
# Leave unset or "default" for local development
SPRING_PROFILES_ACTIVE=prod

# JWT
JWT_SECRET=changeme