### Test 24: Smart Update - Keep Existing Bank (The Critical Test)
# UPDATE THE ID BELOW: Use the ID from Test 23 (e.g., 5 or 10)
# We update Description but do NOT send 'accountNumber'.
# EXPECTATION: The bank link should remain (NOT turn into Cash).
PUT http://localhost:8080/api/transactions/5
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJmdWxsTmFtZSI6Ikt1bmx1MjgxNiIsImVtYWlsIjoia3VubHVfdGVzdEBnbWFpbC5jb20iLCJzdWIiOiJrdW5sdV90ZXN0QGdtYWlsLmNvbSIsImlhdCI6MTc2OTAxMDc1NSwiZXhwIjoxNzY5MDk3MTU1fQ.KIOrWAawYB8qGSnncj7mXqlmEKdPK4Mh6OVmYUvq3KQ
Content-Type: application/json

{
  "amount": 500000,
  "type": "OUT",
  "category": "Internet",
  "description": "Internet Bill - Updated Desc Only"
}

